{
  "name": "@gad-lang/prism-gad",
  "version": "0.1.0",
  "description": "PrismJS syntax highlighting grammar for the Gad scripting language.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gad-lang/gad.git",
    "directory": "web/prism-gad"
  },
  "homepage": "https://github.com/gad-lang/gad/tree/main/web/prism-gad#readme",
  "bugs": "https://github.com/gad-lang/gad/issues",
  "keywords": [
    "gad",
    "prism",
    "prismjs",
    "language",
    "syntax-highlighting",
    "grammar"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "demo": "bun ./example/index.html",
    "demo:build": "bun build ./example/index.html --outdir ./example/dist"
  },
  "peerDependencies": {
    "prismjs": "^1.29.0"
  },
  "devDependencies": {
    "@types/prismjs": "^1.26.0",
    "prismjs": "^1.29.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
