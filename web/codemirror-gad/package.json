{
  "name": "@gad-lang/codemirror-gad",
  "version": "0.1.0",
  "description": "CodeMirror 6 language support for the Gad scripting language: highlighting, autocompletion and async diagnostics.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gad-lang/gad.git",
    "directory": "web/codemirror-gad"
  },
  "homepage": "https://github.com/gad-lang/gad/tree/main/web/codemirror-gad#readme",
  "bugs": "https://github.com/gad-lang/gad/issues",
  "keywords": [
    "gad",
    "codemirror",
    "codemirror6",
    "language",
    "syntax-highlighting",
    "autocomplete"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "demo": "bun ./example/index.html",
    "demo:build": "bun build ./example/index.html --outdir ./example/dist"
  },
  "peerDependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/highlight": "^1.0.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@lezer/highlight": "^1.2.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
