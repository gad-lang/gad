// use_strings.gad — the builtin `strings` module (available without import).

s := "  Gad Lang  "
println("upper:  ", strings.toUpper(s))
println("lower:  ", strings.toLower(s))
println("trimmed:", strings.trimSpace(s))
println("split:  ", strings.split("a,b,c", ","))
println("hasPfx: ", strings.hasPrefix("gadlang", "gad"))
println("replace:", strings.replace("aaa", "a", "b", -1))

return strings.toUpper("done")
